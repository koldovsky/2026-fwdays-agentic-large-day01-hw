  .Dialog--fullscreen {
    .Modal {
      padding: 0;
    }

    .Modal__content {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      max-width: 100%;
      border: 0;
      border-radius: 0;
    }
  }
}
