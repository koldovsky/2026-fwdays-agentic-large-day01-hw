  .color-picker__input-label {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: 8px;
    align-items: center;
    border: 1px solid var(--default-border-color);
    border-radius: 8px;
    padding: 0 12px;
    margin: 8px;
    box-sizing: border-box;

    &:focus-within {
      box-shadow: 0 0 0 1px var(--color-primary-darkest);
