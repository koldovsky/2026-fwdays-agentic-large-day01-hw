      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.25rem 0;
      color: var(--color-gray-60);
      transition: color 0.2s ease;
      flex-shrink: 0;

      &.invisible {
        visibility: hidden;
        pointer-events: none;
      }

      &:hover {
        color: var(--color-primary);
