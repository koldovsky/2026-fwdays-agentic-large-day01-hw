    0% {
      stroke-dasharray: 1, 300;
      stroke-dashoffset: 0;
    }
    50% {
      stroke-dasharray: 150, 300;
      stroke-dashoffset: -200;
    }
    100% {
      stroke-dasharray: 1, 300;
      stroke-dashoffset: -280;
    }
  }
}
