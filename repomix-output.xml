    }

    &__cursor {
      display: inline-block;
      margin-left: 2px;
      color: currentColor;
      animation: blink 1s infinite;
    }

    &__loading {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    &__typing-indicator {
      display: flex;
      gap: 0.25rem;

      span {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
