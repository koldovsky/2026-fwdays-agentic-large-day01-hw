# ── Build artifacts ──────────────────────────────────────────────────
node_modules/
dist/
build/
dev-dist/
coverage/
html/
logs/
firebase/

# ── Lock files ───────────────────────────────────────────────────────
yarn.lock
package-lock.json
yarn-debug.log*
yarn-error.log*
npm-debug.log*
*.log
*.tgz

# ── Generated TypeScript from WASM binaries ───────────────────────────
# Built by scripts/buildWasm.js — contain base64-encoded .wasm, "GENERATED CODE -- DO NOT EDIT"
packages/excalidraw/subset/woff2/woff2-wasm.ts
packages/excalidraw/subset/harfbuzz/harfbuzz-wasm.ts

# ── Subsetted font files (hash-named, auto-generated) ────────────────
# Hundreds of .woff2 files with MD5 hashes in names, generated by font-subsetting pipeline
packages/excalidraw/fonts/**/*.woff2
packages/excalidraw/fonts/**/*.sfd
public/*.woff2

# ── Binary WASM + source TTF assets ──────────────────────────────────
scripts/wasm/
scripts/woff2/assets/

# ── Vitest snapshot files ─────────────────────────────────────────────
# Auto-generated by `yarn test --update`, not for AI reading
**/__snapshots__/
**/*.snap

# ── Auto-generated locale coverage ───────────────────────────────────
# Built by scripts/build-locales-coverage.js
packages/excalidraw/locales/percentages.json

# ── Auto-generated changelogs ─────────────────────────────────────────
# Updated by scripts/updateChangelog.js on release
packages/excalidraw/CHANGELOG.md
packages/utils/CHANGELOG.md

# ── Generated TypeScript types from build ────────────────────────────
packages/excalidraw/types

# ── IDE / OS / misc ──────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
.vercel/
.yarn/
.history/
.eslintcache
.claude
.envrc
.env.development.local
.env.local
.env.production.local
.env.test.local
meta*.json
