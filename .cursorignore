# Build artifacts
dist/
build/
.next/

# Dependencies
node_modules/

# Generated / minified
*.min.js
*.min.css
*.snap

# Repomix / інші дампи репо для LLM (autogenerated)
repomix-output.*
repomix-*.txt

# WASM: бінарники (scripts/wasm) і згенеровані TS з base64 (buildWasm.js → subset/*-wasm.ts)
scripts/wasm/*.wasm
packages/excalidraw/subset/**/*-wasm.ts

# Шрифти: бінарні woff2 і джерела .sfd (шум у Repomix / контексті)
packages/excalidraw/fonts/**/*.woff2
packages/excalidraw/fonts/**/*.sfd
public/**/*.woff2

# Згенеровані типи пакета excalidraw (tsc → dist/types)
packages/excalidraw/types/

# Lock files (великі, не несуть семантики для AI)
yarn.lock
package-lock.json

# Coverage & reports
coverage/
.nyc_output/

# IDE-specific (не наш контекст)
.git/
.vscode/
