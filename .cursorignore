# ---------------------------------------------------------------
# Lock files — large generated dependency graphs, not useful for
# code understanding and expensive on context.
# ---------------------------------------------------------------
yarn.lock

# ---------------------------------------------------------------
# Generated WASM TypeScript files — contain large base64-encoded
# WASM blobs produced by scripts/buildWasm.js. Marked internally
# with "GENERATED CODE -- DO NOT EDIT!"
# ---------------------------------------------------------------
packages/excalidraw/subset/woff2/woff2-wasm.ts
packages/excalidraw/subset/harfbuzz/harfbuzz-wasm.ts
packages/excalidraw/fonts/wasm/**

# ---------------------------------------------------------------
# TypeScript incremental build info — binary-like metadata files
# emitted by tsc --incremental.
# ---------------------------------------------------------------
*.tsbuildinfo

# ---------------------------------------------------------------
# Test snapshots — auto-updated by Vitest/Jest on each test run,
# reviewed as a diff, not useful for general code exploration.
# ---------------------------------------------------------------
**/__snapshots__/**

# ---------------------------------------------------------------
# Next.js example outputs — generated at build time.
# ---------------------------------------------------------------
examples/with-nextjs/.next/
examples/with-nextjs/out/
examples/with-nextjs/next-env.d.ts

# ---------------------------------------------------------------
# Copied static assets — woff2/font files copied from packages
# into example app public directories during build.
# ---------------------------------------------------------------
examples/**/public/**/*.woff2

# ---------------------------------------------------------------
# PWA Workbox precache output — generated by the Vite PWA plugin
# into public/workbox during build.
# ---------------------------------------------------------------
public/workbox/

# ---------------------------------------------------------------
# Mirrored from .gitignore
# ---------------------------------------------------------------
.DS_Store
.env.development.local
.env.local
.env.production.local
.env.test.local
.envrc
.eslintcache
.history
.idea
.vercel
.vscode
.yarn
*.log
*.tgz
build
dist
firebase
logs
node_modules
npm-debug.log*
package-lock.json
yarn-debug.log*
yarn-error.log*
packages/excalidraw/types
coverage
dev-dist
html
meta*.json
.claude
*.min.css
*.min.js
*.snap
.next/
+.nyc_output/