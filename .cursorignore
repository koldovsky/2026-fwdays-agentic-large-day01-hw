# Cursor: exclude autogenerated / machine-produced paths from indexing (gitignore-style syntax).

# --- Dependencies & lockfiles ---
node_modules/
.yarn/
package-lock.json
yarn.lock
examples/with-nextjs/yarn.lock

# --- Build & bundle outputs ---
build/
dist/
dev-dist/
html/
coverage/
packages/excalidraw/types/
meta*.json
firebase/

