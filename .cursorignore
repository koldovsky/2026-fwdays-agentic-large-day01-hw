packages/excalidraw/locales/percentages.json

# --- cn-font-split font bundles ---
packages/excalidraw/fonts/ComicShanns/index.ts
packages/excalidraw/fonts/Excalifont/index.ts
packages/excalidraw/fonts/Xiaolai/index.ts

# --- scripts/buildWasm.js (base64 wasm modules) ---
packages/excalidraw/fonts/wasm/
