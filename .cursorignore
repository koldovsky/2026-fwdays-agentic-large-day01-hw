coverage/
.nyc_output/
html/

# Repomix / агреговані дампи репо (не вихідний код)
repomix-*.txt
repomix-output.xml

# CodeGraphContext — локальний індекс (KuzuDB тощо), див. docs/reference/codegraphcontext.md
.cgc_home/

