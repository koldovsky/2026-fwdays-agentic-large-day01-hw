# --- Cursor context: Tier A (high impact, low risk) ---

# Lockfiles (repeatable; package.json remains for deps)
yarn.lock
examples/**/yarn.lock

# WASM embedded as TS (base64)
packages/excalidraw/subset/**/*-wasm.ts
packages/excalidraw/fonts/wasm/*.ts

# Jest snapshots
**/__snapshots__/**/*.snap

# Font binaries
packages/excalidraw/fonts/**/*.woff2

# --- Cursor context: Tier B (more aggressive) ---

# Woff2 emscripten bindings (vendored glue)
packages/excalidraw/subset/woff2/woff2-bindings.ts

# i18n (keep English via negation — Cursor supports ! like gitignore)
packages/excalidraw/locales/*.json
!packages/excalidraw/locales/en.json

# Example apps (only if you don't edit them from Cursor)
# examples/

# PWA build output (if present)
public/workbox
